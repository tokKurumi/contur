{
    "version": 4,
    "configurations": [
        {
            "name": "contur2-Debug",
            "compileCommands": "${workspaceFolder}/src/build/debug/compile_commands.json",
            "intelliSenseMode": "clang-x64",
            "cppStandard": "c++20",
            "cStandard": "c17",
