{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build contur2 (Debug)",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/src/build.sh",
                "debug",
                "${workspaceFolder}/src"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-ExecutionPolicy", "Bypass",
                    "-File", "${workspaceFolder}/src/build.ps1",
                    "-Preset", "debug",
                    "-SourceDir", "${workspaceFolder}/src"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Build contur2 (Release)",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/src/build.sh",
                "release",
                "${workspaceFolder}/src"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-ExecutionPolicy", "Bypass",
                    "-File", "${workspaceFolder}/src/build.ps1",
                    "-Preset", "release",
                    "-SourceDir", "${workspaceFolder}/src"
                ]
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Tests (Debug)",
            "type": "shell",
            "command": "ctest",
            "args": ["--preset", "debug", "--output-on-failure"],
            "windows": {
                "args": ["--preset", "win-debug", "--output-on-failure"]
            },
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Run Tests (Release)",
            "type": "shell",
            "command": "ctest",
            "args": ["--preset", "release", "--output-on-failure"],
            "windows": {
                "args": ["--preset", "win-release", "--output-on-failure"]
            },
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Clear build artifacts",
            "type": "shell",
            "command": "rm -rf ${workspaceFolder}/src/build/*",
            "windows": {
                "command": "powershell",
                "args": [
                    "-Command",
                    "Remove-Item -Recurse -Force '${workspaceFolder}/src/build/*' -ErrorAction SilentlyContinue"
                ]
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Format Code (All Files)",
            "type": "shell",
            "command": "bash",
            "args": [
                "${workspaceFolder}/misc/format.sh"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-ExecutionPolicy", "Bypass",
                    "-File", "${workspaceFolder}/misc/format.ps1"
                ]
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Format Code (Current File)",
            "type": "shell",
            "command": "clang-format",
            "args": [
                "-i",
                "${file}"
            ],
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Generate Doxygen Docs (Debug)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "command": "bash",
            "args": [
                "-c",
                "./build.sh debug . && cmake --build --preset debug --target docs"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-ExecutionPolicy",
                    "Bypass",
                    "-Command",
                    "& { Set-Location -Path '${workspaceFolder}/src'; .\\build.ps1 -Preset debug -SourceDir '${workspaceFolder}/src'; cmake --build --preset debug --target docs }"
                ],
                "options": {
                    "cwd": "${workspaceFolder}/src"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Generate Doxygen Docs (Release)",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/src"
            },
            "command": "bash",
            "args": [
                "-c",
                "./build.sh release . && cmake --build --preset release --target docs"
            ],
            "windows": {
                "command": "powershell",
                "args": [
                    "-ExecutionPolicy",
                    "Bypass",
                    "-Command",
                    "& { Set-Location -Path '${workspaceFolder}/src'; .\\build.ps1 -Preset release -SourceDir '${workspaceFolder}/src'; cmake --build --preset release --target docs }"
                ],
                "options": {
                    "cwd": "${workspaceFolder}/src"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
    ]
}
